{
  "name": "todo-app",
  "version": "1.0.6",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "e2e:open": "start-server-and-test 'vite dev --port 4173' http://localhost:4173 'cypress open --e2e'",
    "e2e:run": "start-server-and-test 'vite build --mode test && vite preview --mode test --port 4173' http://localhost:4173 'cypress run --browser chrome --e2e'",
    "build-only": "vite build",
    "type-check": "vue-tsc --noEmit -p tsconfig.vitest.json --composite false",
    "lint": "eslint . --ignore-pattern .gitignore",
    "lint:fix": "eslint . --fix --ignore-pattern .gitignore",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "@headlessui/vue": "^1.7.23",
    "@heroicons/vue": "^2.2.0",
    "@tiptap/extension-bold": "^3.21.0",
    "@tiptap/extension-bullet-list": "^3.21.0",
    "@tiptap/extension-link": "^3.21.0",
    "@tiptap/extension-ordered-list": "^3.21.0",
    "@tiptap/extension-paragraph": "^3.21.0",
    "@tiptap/extension-placeholder": "^3.21.0",
    "@tiptap/extension-underline": "^3.21.0",
    "@tiptap/pm": "^3.21.0",
    "@tiptap/starter-kit": "^3.21.0",
    "@tiptap/vue-3": "^3.21.0",
    "@vueform/toggle": "^2.1.4",
    "@vuepic/vue-datepicker": "^12.1.0",
    "@vueuse/core": "^14.2.1",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.31",
    "vue-router": "^5.0.4",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@rushstack/eslint-patch": "^1.10.4",
    "@tailwindcss/postcss": "^4.0.17",
    "@tailwindcss/vite": "^4.0.17",
    "@tsconfig/node20": "^20.1.4",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^20.16.11",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "@vitest/eslint-plugin": "1.1.7",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.5.1",
    "cypress": "^15.13.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.1.0",
    "eslint-plugin-cypress": "^4.0.0",
    "eslint-plugin-vue": "^10.8.0",
    "jsdom": "^25.0.1",
    "npm-run-all2": "^6.2.3",
    "postcss": "^8.4.47",
    "prettier": "^3.3.3",
    "rollup-plugin-visualizer": "^5.14.0",
    "sass-embedded": "^1.98.0",
    "start-server-and-test": "^2.0.8",
    "tailwindcss": "^4.0.17",
    "typescript": "~5.5.4",
    "vite": "^8.0.3",
    "vitest": "^3.0.7",
    "vue-tsc": "^2.1.6"
  },
  "browserslist": [
    "defaults"
  ],
  "overrides": {
    "rolldown": "1.0.0-rc.12"
  }
}
